# Copy this file to ".env" and fill in your real key.
# The real .env is git-ignored and never leaves your computer.

ANTHROPIC_API_KEY=sk-ant-your-key-here
GEARHEAD_MODEL=claude-opus-4-8

# Brain selection: claude | ollama | auto (default: auto = claude if a key is set).
# Ollama mode is free and fully offline — no API key needed at all.
# GEARHEAD_PROVIDER=ollama
# GEARHEAD_OLLAMA_MODEL=qwen2.5:7b-instruct
# GEARHEAD_OLLAMA_HOST=http://127.0.0.1:11434
